# Production server environment for vidssave.shop API.
# Copy this to server.env or your host's environment manager and edit paths for Linux.

NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# Public domains used by deployment/CORS.
PUBLIC_PARENT_ORIGIN=https://vidssave.online
PUBLIC_DOWNLOADER_ORIGIN=https://vidssave.shop
PUBLIC_API_ORIGIN=https://api.vidssave.shop
CORS_ORIGINS=https://vidssave.shop,https://www.vidssave.shop,https://vidssave.online,https://www.vidssave.online

# Fast merged-download preparation.
PARALLEL_MERGE_PREPARE=true
YTDLP_CONCURRENT_FRAGMENTS=16
YTDLP_HTTP_CHUNK_SIZE=10M

# Keep this false unless production testing proves aria2 is faster on the VPS.
YTDLP_USE_ARIA2=false
ARIA2C_MAX_CONNECTIONS=16
ARIA2C_SPLIT=16
ARIA2C_MIN_SPLIT_SIZE=1M

# Linux production paths usually resolve from PATH.
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
FFMPEG_LOCATION=
ARIA2C_PATH=aria2c

# Optional YouTube extraction/auth tuning.
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_PROXY=
YTDLP_EXTRACTOR_ARGS=
YTDLP_FORCE_IPV4=false
YTDLP_THROTTLED_RATE=
YTDLP_INFO_CHECK_FORMATS=false
YOUTUBEI_FAST_INFO=true

# API cache path. Use a writable local disk path on the VPS.
VIDEO_INFO_CACHE_DIR=/var/www/video-downloader/.cache/video-info

# Only needed if database-backed features are enabled.
DATABASE_URL=
