# API server env. For production VPS, copy values from ../../server.env.example.

NODE_ENV=production
PORT=5000
LOG_LEVEL=info
PUBLIC_PARENT_ORIGIN=https://vidssave.online
PUBLIC_DOWNLOADER_ORIGIN=https://vidssave.shop
PUBLIC_API_ORIGIN=https://api.vidssave.shop
CORS_ORIGINS=https://vidssave.shop,https://www.vidssave.shop,https://vidssave.online,https://www.vidssave.online

PARALLEL_MERGE_PREPARE=true
YTDLP_CONCURRENT_FRAGMENTS=16
YTDLP_HTTP_CHUNK_SIZE=10M
YTDLP_USE_ARIA2=false

YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
FFMPEG_LOCATION=
ARIA2C_PATH=aria2c

YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_PROXY=
YTDLP_EXTRACTOR_ARGS=
YTDLP_FORCE_IPV4=false
YTDLP_THROTTLED_RATE=
YTDLP_INFO_CHECK_FORMATS=false
YOUTUBEI_FAST_INFO=true

VIDEO_INFO_CACHE_DIR=.cache/video-info
DATABASE_URL=
